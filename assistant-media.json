{
  "swagger": "2.0",
  "info": {
    "title": "PubMed E-utilities",
    "description": "NCBI PubMed E-utilities REST API connector for Power Apps / Power Automate. Provides literature search (esearch), article summaries (esummary), full record fetch (efetch), and database info (einfo).",
    "version": "1.0",
    "contact": {
      "name": "NCBI E-utilities",
      "url": "https://www.ncbi.nlm.nih.gov/books/NBK25500/"
    }
  },
  "host": "eutils.ncbi.nlm.nih.gov",
  "basePath": "/entrez/eutils",
  "schemes": ["https"],
  "consumes": [],
  "produces": ["application/json", "application/xml", "text/plain"],
  "paths": {
    "/esearch.fcgi": {
      "get": {
        "summary": "Search PubMed",
        "description": "Search PubMed (or any Entrez database) and return matching IDs (PMIDs for pubmed).",
        "operationId": "SearchPubMed",
        "parameters": [
          {
            "name": "db",
            "in": "query",
            "required": true,
            "type": "string",
            "default": "pubmed",
            "description": "Entrez database to search (pubmed, pmc, gene, protein, etc.)",
            "x-ms-summary": "Database"
          },
          {
            "name": "term",
            "in": "query",
            "required": true,
            "type": "string",
            "description": "Search query. Supports Entrez syntax e.g. 'CRISPR AND 2025[pdat]' or 'cancer[mesh] AND review[ptyp]'",
            "x-ms-summary": "Search term"
          },
          {
            "name": "retmax",
            "in": "query",
            "required": false,
            "type": "integer",
            "default": 20,
            "minimum": 1,
            "maximum": 10000,
            "description": "Max number of IDs to return (1-10000)",
            "x-ms-summary": "Max results"
          },
          {
            "name": "retstart",
            "in": "query",
            "required": false,
            "type": "integer",
            "default": 0,
            "description": "Offset for pagination (0-based)",
            "x-ms-summary": "Start offset"
          },
          {
            "name": "sort",
            "in": "query",
            "required": false,
            "type": "string",
            "enum": ["relevance", "pub_date", "Author", "JournalName", "most+recent"],
            "default": "relevance",
            "description": "Sort order",
            "x-ms-summary": "Sort by"
          },
          {
            "name": "mindate",
            "in": "query",
            "required": false,
            "type": "string",
            "description": "Minimum publication date (YYYY, YYYY/MM, or YYYY/MM/DD). Must be paired with maxdate.",
            "x-ms-summary": "Min date"
          },
          {
            "name": "maxdate",
            "in": "query",
            "required": false,
            "type": "string",
            "description": "Maximum publication date (YYYY, YYYY/MM, or YYYY/MM/DD). Must be paired with mindate.",
            "x-ms-summary": "Max date"
          },
          {
            "name": "datetype",
            "in": "query",
            "required": false,
            "type": "string",
            "enum": ["pdat", "edat", "mdat"],
            "default": "pdat",
            "description": "Type of date used for mindate/maxdate (pdat=publication, edat=Entrez, mdat=modification)",
            "x-ms-summary": "Date type"
          },
          {
            "name": "retmode",
            "in": "query",
            "required": true,
            "type": "string",
            "enum": ["json", "xml"],
            "default": "json",
            "description": "Return format",
            "x-ms-summary": "Return mode"
          },
          {
            "name": "api_key",
            "in": "query",
            "required": false,
            "type": "string",
            "description": "NCBI API key (raises rate limit from 3 to 10 req/s)",
            "x-ms-summary": "API key",
            "x-ms-visibility": "advanced"
          },
          {
            "name": "tool",
            "in": "query",
            "required": false,
            "type": "string",
            "default": "PowerAppsConnector",
            "description": "Tool name (required by NCBI guidelines)",
            "x-ms-summary": "Tool name",
            "x-ms-visibility": "advanced"
          },
          {
            "name": "email",
            "in": "query",
            "required": false,
            "type": "string",
            "description": "Contact email (required by NCBI guidelines)",
            "x-ms-summary": "Contact email",
            "x-ms-visibility": "advanced"
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "schema": {
              "$ref": "#/definitions/ESearchResponse"
            }
          },
          "400": {"description": "Bad request"},
          "429": {"description": "Rate limit exceeded"}
        }
      }
    },
    "/esummary.fcgi": {
      "get": {
        "summary": "Get PubMed Article Summaries",
        "description": "Retrieve document summaries (title, authors, journal, pubdate, DOI, etc.) for a list of PMIDs.",
        "operationId": "GetPubMedSummaries",
        "parameters": [
          {
            "name": "db",
            "in": "query",
            "required": true,
            "type": "string",
            "default": "pubmed",
            "x-ms-summary": "Database"
          },
          {
            "name": "id",
            "in": "query",
            "required": true,
            "type": "string",
            "description": "Comma-separated PMIDs (max 200 per request)",
            "x-ms-summary": "PMIDs (comma-separated)"
          },
          {
            "name": "retmode",
            "in": "query",
            "required": true,
            "type": "string",
            "enum": ["json", "xml"],
            "default": "json",
            "x-ms-summary": "Return mode"
          },
          {
            "name": "version",
            "in": "query",
            "required": false,
            "type": "string",
            "enum": ["2.0"],
            "default": "2.0",
            "description": "esummary version (2.0 = richer schema)",
            "x-ms-summary": "API version",
            "x-ms-visibility": "advanced"
          },
          {
            "name": "api_key",
            "in": "query",
            "required": false,
            "type": "string",
            "x-ms-summary": "API key",
            "x-ms-visibility": "advanced"
          },
          {
            "name": "tool",
            "in": "query",
            "required": false,
            "type": "string",
            "default": "PowerAppsConnector",
            "x-ms-summary": "Tool name",
            "x-ms-visibility": "advanced"
          },
          {
            "name": "email",
            "in": "query",
            "required": false,
            "type": "string",
            "x-ms-summary": "Contact email",
            "x-ms-visibility": "advanced"
          }
        ],
        "responses": {
          "200": {
            "description": "Article summaries",
            "schema": {
              "$ref": "#/definitions/ESummaryResponse"
            }
          },
          "400": {"description": "Bad request"},
          "429": {"description": "Rate limit exceeded"}
        }
      }
    },
    "/efetch.fcgi": {
      "get": {
        "summary": "Fetch Full PubMed Records",
        "description": "Retrieve full records (abstracts, MeSH terms, full citation) for a list of PMIDs. Note: efetch for pubmed only supports XML/text, not JSON.",
        "operationId": "FetchPubMedRecords",
        "parameters": [
          {
            "name": "db",
            "in": "query",
            "required": true,
            "type": "string",
            "default": "pubmed",
            "x-ms-summary": "Database"
          },
          {
            "name": "id",
            "in": "query",
            "required": true,
            "type": "string",
            "description": "Comma-separated PMIDs",
            "x-ms-summary": "PMIDs (comma-separated)"
          },
          {
            "name": "rettype",
            "in": "query",
            "required": false,
            "type": "string",
            "enum": ["abstract", "medline", "uilist", "xml"],
            "default": "abstract",
            "description": "Record type",
            "x-ms-summary": "Record type"
          },
          {
            "name": "retmode",
            "in": "query",
            "required": false,
            "type": "string",
            "enum": ["xml", "text"],
            "default": "xml",
            "description": "Return mode (pubmed efetch does NOT support json)",
            "x-ms-summary": "Return mode"
          },
          {
            "name": "api_key",
            "in": "query",
            "required": false,
            "type": "string",
            "x-ms-summary": "API key",
            "x-ms-visibility": "advanced"
          },
          {
            "name": "tool",
            "in": "query",
            "required": false,
            "type": "string",
            "default": "PowerAppsConnector",
            "x-ms-summary": "Tool name",
            "x-ms-visibility": "advanced"
          },
          {
            "name": "email",
            "in": "query",
            "required": false,
            "type": "string",
            "x-ms-summary": "Contact email",
            "x-ms-visibility": "advanced"
          }
        ],
        "responses": {
          "200": {
            "description": "Full records (XML or text)",
            "schema": {"type": "string"}
          },
          "400": {"description": "Bad request"},
          "429": {"description": "Rate limit exceeded"}
        }
      }
    },
    "/einfo.fcgi": {
      "get": {
        "summary": "Get Database Info",
        "description": "List all Entrez databases or get statistics for a specific database (record count, last update, available search fields).",
        "operationId": "GetDatabaseInfo",
        "parameters": [
          {
            "name": "db",
            "in": "query",
            "required": false,
            "type": "string",
            "description": "Database name (omit to list all databases)",
            "x-ms-summary": "Database"
          },
          {
            "name": "retmode",
            "in": "query",
            "required": true,
            "type": "string",
            "enum": ["json", "xml"],
            "default": "json",
            "x-ms-summary": "Return mode"
          },
          {
            "name": "api_key",
            "in": "query",
            "required": false,
            "type": "string",
            "x-ms-summary": "API key",
            "x-ms-visibility": "advanced"
          }
        ],
        "responses": {
          "200": {
            "description": "Database info",
            "schema": {"type": "object"}
          }
        }
      }
    }
  },
  "definitions": {
    "ESearchResponse": {
      "type": "object",
      "properties": {
        "header": {
          "type": "object",
          "properties": {
            "type": {"type": "string"},
            "version": {"type": "string"}
          }
        },
        "esearchresult": {
          "type": "object",
          "properties": {
            "count": {"type": "string", "description": "Total matching records"},
            "retmax": {"type": "string"},
            "retstart": {"type": "string"},
            "idlist": {
              "type": "array",
              "items": {"type": "string"},
              "description": "Array of PMIDs"
            },
            "translationset": {"type": "array", "items": {"type": "object"}},
            "querytranslation": {"type": "string", "description": "How NCBI parsed your query"}
          }
        }
      }
    },
    "ESummaryResponse": {
      "type": "object",
      "properties": {
        "header": {
          "type": "object",
          "properties": {
            "type": {"type": "string"},
            "version": {"type": "string"}
          }
        },
        "result": {
          "type": "object",
          "description": "Keyed by PMID. Use 'uids' array to enumerate. Each PMID key contains the article summary.",
          "properties": {
            "uids": {
              "type": "array",
              "items": {"type": "string"}
            }
          },
          "additionalProperties": {
            "$ref": "#/definitions/ArticleSummary"
          }
        }
      }
    },
    "ArticleSummary": {
      "type": "object",
      "properties": {
        "uid": {"type": "string", "description": "PMID"},
        "pubdate": {"type": "string"},
        "epubdate": {"type": "string"},
        "source": {"type": "string", "description": "Journal abbreviation"},
        "authors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {"type": "string"},
              "authtype": {"type": "string"},
              "clusterid": {"type": "string"}
            }
          }
        },
        "lastauthor": {"type": "string"},
        "title": {"type": "string"},
        "sorttitle": {"type": "string"},
        "volume": {"type": "string"},
        "issue": {"type": "string"},
        "pages": {"type": "string"},
        "lang": {"type": "array", "items": {"type": "string"}},
        "nlmuniqueid": {"type": "string"},
        "issn": {"type": "string"},
        "essn": {"type": "string"},
        "pubtype": {"type": "array", "items": {"type": "string"}},
        "recordstatus": {"type": "string"},
        "pubstatus": {"type": "string"},
        "articleids": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "idtype": {"type": "string"},
              "idtypen": {"type": "integer"},
              "value": {"type": "string"}
            }
          }
        },
        "history": {"type": "array", "items": {"type": "object"}},
        "references": {"type": "array", "items": {"type": "object"}},
        "attributes": {"type": "array", "items": {"type": "string"}},
        "pmcrefcount": {"type": "string"},
        "fulljournalname": {"type": "string"},
        "elocationid": {"type": "string", "description": "Usually contains DOI"},
        "doctype": {"type": "string"},
        "srccontriblist": {"type": "array", "items": {"type": "object"}},
        "booktitle": {"type": "string"},
        "medium": {"type": "string"},
        "edition": {"type": "string"},
        "publisherlocation": {"type": "string"},
        "publishername": {"type": "string"},
        "srcdate": {"type": "string"},
        "reportnumber": {"type": "string"},
        "availablefromurl": {"type": "string"},
        "locationlabel": {"type": "string"},
        "doccontriblist": {"type": "array", "items": {"type": "object"}},
        "docdate": {"type": "string"},
        "bookname": {"type": "string"},
        "chapter": {"type": "string"},
        "sortpubdate": {"type": "string"},
        "sortfirstauthor": {"type": "string"},
        "vernaculartitle": {"type": "string"}
      }
    }
  }
}
