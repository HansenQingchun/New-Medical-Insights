{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "searchLocation": {
      "value": "${AZURE_SEARCH_LOCATION=${AZURE_LOCATION}}"
    },
    "principalId": {
      "value": "${AZURE_PRINCIPAL_ID}"
    },
    "chatModelName": {
      "value": "${NMI_CHAT_MODEL=gpt-4o}"
    },
    "chatModelVersion": {
      "value": "${NMI_CHAT_MODEL_VERSION=2024-11-20}"
    },
    "chatModelCapacity": {
      "value": "${NMI_CHAT_MODEL_CAPACITY=30}"
    }
  }
}
